{
    "settings": {
        "register_with_account": false
    },
    "rules": [
        {
            "patterns": [
                "/new$",
                "/edit$",
                "/foods/[0-9]+$"
            ],
            "properties": {
                "context": "modal",
                "uri": "hotwire://fragment/web/modal/sheet"
            }
        },
        {
            "patterns": [
                ".*"
            ],
            "properties": {
                "context": "default",
                "uri": "hotwire://fragment/web"
            }
        }
    ]
}