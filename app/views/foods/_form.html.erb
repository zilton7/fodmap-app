<%= form_with(model: food, class: "space-y-6") do |form| %>
  <% if food.errors.any? %>
    <div class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(food.errors.count, "error") %> prohibited this food from being saved:</h2>
      <ul>
        <% food.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-4">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
      </div>

      <div>
        <%= form.label :category, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :category, Food.categories.keys.map { |c| [c.titleize, c] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
      </div>

      <div>
        <%= form.label :overall_status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :overall_status, Food.overall_statuses.keys.map { |s| [s.titleize, s] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
      </div>

      <div>
        <%= form.label :image_file_name, "Image File Name (Optional)", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :image_file_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
      </div>

      <div>
        <%= form.label :notes, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <h3 class="text-md font-semibold mb-3">Small Portion (Standard)</h3>
        <div class="space-y-3">
          <div>
            <%= form.label :small_portion_desc, "Description", class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :small_portion_desc, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= form.label :small_portion_oligos, "Oligos", class: "block text-sm font-medium text-gray-700" %>
              <%= form.select :small_portion_oligos, Food.small_portion_oligos.keys.map { |k| [k.sub('small_portion_oligos_','').titleize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
            </div>
            <div>
              <%= form.label :small_portion_fructose, "Fructose", class: "block text-sm font-medium text-gray-700" %>
              <%= form.select :small_portion_fructose, Food.small_portion_fructoses.keys.map { |k| [k.sub('small_portion_fructose_','').titleize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
            </div>
            <div>
              <%= form.label :small_portion_polyols, "Polyols", class: "block text-sm font-medium text-gray-700" %>
              <%= form.select :small_portion_polyols, Food.small_portion_polyols.keys.map { |k| [k.sub('small_portion_polyols_','').titleize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
            </div>
            <div>
              <%= form.label :small_portion_lactose, "Lactose", class: "block text-sm font-medium text-gray-700" %>
              <%= form.select :small_portion_lactose, Food.small_portion_lactoses.keys.map { |k| [k.sub('small_portion_lactose_','').titleize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <h3 class="text-md font-semibold mb-3">Large Portion (Optional)</h3>
        <div class="space-y-3">
          <div>
            <%= form.label :large_portion_desc, "Description", class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :large_portion_desc, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= form.label :large_portion_oligos, "Oligos", class: "block text-sm font-medium text-gray-700" %>
              <%= form.select :large_portion_oligos, Food.large_portion_oligos.keys.map { |k| [k.sub('large_portion_oligos_','').titleize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border", prompt: "Select status" %>
            </div>
            <div>
              <%= form.label :large_portion_fructose, "Fructose", class: "block text-sm font-medium text-gray-700" %>
              <%= form.select :large_portion_fructose, Food.large_portion_fructoses.keys.map { |k| [k.sub('large_portion_fructose_','').titleize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border", prompt: "Select status" %>
            </div>
            <div>
              <%= form.label :large_portion_polyols, "Polyols", class: "block text-sm font-medium text-gray-700" %>
              <%= form.select :large_portion_polyols, Food.large_portion_polyols.keys.map { |k| [k.sub('large_portion_polyols_','').titleize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border", prompt: "Select status" %>
            </div>
            <div>
              <%= form.label :large_portion_lactose, "Lactose", class: "block text-sm font-medium text-gray-700" %>
              <%= form.select :large_portion_lactose, Food.large_portion_lactoses.keys.map { |k| [k.sub('large_portion_lactose_','').titleize, k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border", prompt: "Select status" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3 pt-6 border-t border-gray-200 mt-6">
    <%= link_to "Cancel", foods_path, class: "px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    <%= form.submit class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer" %>
  </div>
<% end %>
