<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Edit Food</h1>
      <p class="mt-2 text-sm text-gray-500">Update details for <%= @food.name %>.</p>
    </div>
    <%= link_to "Show Food", @food, data: { turbo_frame: "modal" }, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <%= render "form", food: @food %>
  </div>
</div>
